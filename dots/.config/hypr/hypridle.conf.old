# $lock_cmd = hyprctl dispatch global quickshell:lock & pidof qs quickshell hyprlock || hyprlock
$lock_cmd = pidof hyprlock || hyprlock
$suspend_cmd = systemctl suspend || loginctl suspend

general {
    lock_cmd = $lock_cmd
    before_sleep_cmd = loginctl lock-session
    after_sleep_cmd = hyprctl dispatch global quickshell:lockFocus
    inhibit_sleep = 3
}

listener {
    timeout = 300 # 10min
    on-timeout = loginctl lock-session
}

listener {
    timeout = 300 # 15mins
    on-timeout = hyprctl dispatch dpms off ; exec openrgb --color 000000 -m direct
    on-resume = hyprctl dispatch dpms on ; exec openrgb.sh ; hyprctl dispatch workspace 2
}

listener {
    timeout = 72000 # 2hrs
    on-timeout = $suspend_cmd
}
